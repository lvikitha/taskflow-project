# ─── Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

# PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/taskflow
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=tiger

# JWT — change this to a long random string in production
JWT_SECRET=taskflow-super-secret-key-change-in-production-must-be-256-bits-long
JWT_EXPIRATION=86400000   # 24 hours in milliseconds

# Google Gemini AI API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Frontend Environment Variables ──────────────────────────────
VITE_API_URL=http://localhost:8080/api
